SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01
# Özel alan adı şifre sıfırlama için virgülle: SHOPIFY_PASSWORD_RESET_ALLOWED_HOSTS=www.site.com,site.com
# Şifre sıfırlama sayfası tabanı: NEXT_PUBLIC_SITE_URL=https://www.site.com
NEXT_PUBLIC_SITE_URL=https://your-site.example.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx
JUDGEME_SHOP_DOMAIN=your-store.myshopify.com
JUDGEME_PUBLIC_TOKEN=your-judgeme-public-token
JUDGEME_API_TOKEN=your-judgeme-api-token
JUDGEME_API_BASE=https://api.judge.me/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_PASSWORD_SECRET=replace-with-a-strong-random-secret
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
ENABLE_DEBUG_LOGS=0
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
NEXT_PUBLIC_FORMSPREE_NEWSLETTER_ENDPOINT=https://formspree.io/f/your-newsletter-form-id
# Çark: aktif indirim kodları Shopify’dan; isteğe bağlı WHEEL_DISCOUNT_PREFIX / WHEEL_DISCOUNT_CODES / WHEEL_GENERATED_CODE_PREFIX
WHEEL_SEGMENTS_PER_PRIZE=3
WHEEL_DISCOUNT_CODES=CODE10,CODE15
WHEEL_DISCOUNT_PERCENTS=10,15
# Kampanya üst barı (fallback): Shopify custom.campaign_banner metafield yoksa buradan okunur.
NEXT_PUBLIC_CAMPAIGN_BAR_ENABLED=0
NEXT_PUBLIC_CAMPAIGN_BAR_MESSAGE=Anneler Günü indirimi: Sepette ekstra %15
NEXT_PUBLIC_CAMPAIGN_BAR_COUNTDOWN_TITLE=Fırsat bitimine
NEXT_PUBLIC_CAMPAIGN_BAR_END_AT=2026-05-10T23:59:59+03:00
NEXT_PUBLIC_CAMPAIGN_BAR_CTA_LABEL=CARKI CEVIR
NEXT_PUBLIC_CAMPAIGN_BAR_CTA_ACTION=spin-wheel
NEXT_PUBLIC_CAMPAIGN_BAR_CTA_HREF=/tum-urunler?filtre=kampanya
# Policy claims Shopify custom.policy_claims metafield yoksa bu varsayılanlar kullanılır.
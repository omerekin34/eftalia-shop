SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Şifre sıfırlama e-postası özel alan adı kullanıyorsa virgülle ekleyin (ör. www.siteniz.com,siteniz.com)
SHOPIFY_PASSWORD_RESET_ALLOWED_HOSTS=
# Headless sitede şifre sıfırlama sayfası için (örn. https://www.siteniz.com)
NEXT_PUBLIC_SITE_URL=https://eftalia-shop-b39c.vercel.app/
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01
JUDGEME_SHOP_DOMAIN=your-store.myshopify.com
JUDGEME_PUBLIC_TOKEN=your-judge-me-public-token
JUDGEME_API_TOKEN=your-judge-me-private-api-token
JUDGEME_PRIVATE_TOKEN=
JUDGEME_API_BASE=https://api.judge.me/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_PASSWORD_SECRET=replace-with-a-strong-random-secret
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
# İade/iptal talepleri ve çark ödülü gibi müşteri JSON metafield yazımı için Admin API şart
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx
WHEEL_DISCOUNT_PREFIX=EFTALIA
WHEEL_DISCOUNT_CODES=EFTALIA10,EFTALIA15,EFTALIA20,EFTALIA25,EFTALIA30
